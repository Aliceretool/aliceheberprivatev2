<Screen
  id="orders"
  _customShortcuts={[]}
  _hashParams={[]}
  _order={0}
  _searchParams={[]}
  browserTitle=""
  title="Page 1"
  urlSlug=""
  uuid="e415729b-9f1c-40e5-8a63-6d8ff9afb155"
>
  <Folder id="Data">
    <State id="defaultVinsFilter" />
    <State
      id="raasInventory"
      value="{{ get_raas_inventory.data?.inventory }}"
    />
    <State
      id="newRaasSupplyPricing"
      value="{{ get_aggregated_raas_cars_groups.value }}"
    />
    <State
      id="newRaasSupply"
      value="{{ get_inventory.data?.inventory ?? { inventory: [] }}}"
    />
    <JavascriptQuery
      id="test"
      query={include("../lib/test.js", "string")}
      resourceName="JavascriptQuery"
    />
  </Folder>
  <Folder id="CreateSupplyOrder">
    <JavascriptQuery
      id="mapPricingToInventory"
      isMultiplayerEdited={false}
      query={include("../lib/mapPricingToInventory.js", "string")}
      resourceName="JavascriptQuery"
    />
    <RESTQuery
      id="get_inventory"
      clonedDemoResourceType="restapi"
      enableMockResponseTransformer={true}
      enableTransformer={true}
      isClonedDemoQuery={true}
      isMultiplayerEdited={false}
      mockResponseTransformer="return "
      notificationDuration={4.5}
      openAPIRequestBody=""
      query={
        "cars?{{ add_supply_vins_filter.value ? 'vins' : null }}={{add_supply_vins_filter.value ? add_supply_vins_filter.value : '' }}&{{ add_supply_partner_selector.value ? 'signedByIds' : null }}={{ add_supply_partner_selector.value ? add_supply_partner_selector.value : '' }}&currentPage=1&perPage=50&{{ add_supply_finnCarIds_filter.value != \"\" ? 'finnCarIds' : null }}={{ add_supply_finnCarIds_filter.value ? add_supply_finnCarIds_filter.value : '' }}&{{ add_supply_car_status_selector.value.length > 0 ? 'carStatus' : null }}={{ add_supply_car_status_selector.value ? add_supply_car_status_selector.value.join(',') : '' }}&{{ add_supply_brands_selector.value.length > 0 ? 'brands' : null }}={{ add_supply_brands_selector.value ? add_supply_brands_selector.value.join(',') : '' }}&{{ add_supply_models_selector.value ? 'models' : null }}={{ add_supply_models_selector.value ? add_supply_models_selector.value : '' }}"
      }
      queryTimeout="50000"
      resourceName="0f27607d-456d-4b72-9d3b-b73575b83a2a"
      resourceTypeOverride=""
      runWhenModelUpdates={false}
      showSuccessToaster={false}
      transformer="return data.data"
    >
      <Event
        id="0e30d391"
        event="success"
        method="setValue"
        params={{ map: { value: "{{ get_inventory.data }}" } }}
        pluginId="newRaasSupply"
        type="state"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="b23dcb26"
        event="success"
        method="trigger"
        params={{}}
        pluginId="mapPricingToInventory"
        type="datasource"
        waitMs="0"
        waitType="debounce"
      />
    </RESTQuery>
    <RESTQuery
      id="get_inventory_gsheet"
      clonedDemoResourceType="restapi"
      enableMockResponseTransformer={true}
      enableTransformer={true}
      isClonedDemoQuery={true}
      isMultiplayerEdited={false}
      mockResponseTransformer="return "
      openAPIRequestBody=""
      query="cars?currentPage=1&perPage=100&vins={{ import_gsheet.data?.length > 0 ? import_gsheet.data?.map(row => row.vin).join(',' ) : '' }}"
      queryTimeout="120000"
      resourceName="0f27607d-456d-4b72-9d3b-b73575b83a2a"
      resourceTypeOverride=""
      runWhenModelUpdates={false}
      transformer="return data.data"
    >
      <Event
        id="60a38553"
        event="success"
        method="setValue"
        params={{ map: { value: "{{ get_inventory_gsheet.data }}" } }}
        pluginId="newRaasSupply"
        type="state"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="06ea7ee9"
        event="success"
        method="trigger"
        params={{}}
        pluginId="mapPricingToInventory"
        type="datasource"
        waitMs="0"
        waitType="debounce"
      />
    </RESTQuery>
    <RESTQuery
      id="import_gsheet"
      _additionalScope={["sheet", "vin_column", "purchase_price_column", "tab"]}
      body={
        '[{"key":"vin_column","value":"{{  vin_column }}"},{"key":"price_column","value":"{{  purchase_price_column }}"},{"key":"sheet","value":"{{  sheet }}"},{"key":"tab","value":"{{ tab }}"}]'
      }
      bodyType="json"
      clonedDemoResourceType="restapi"
      enableMockResponseTransformer={true}
      isClonedDemoQuery={true}
      isMultiplayerEdited={false}
      mockResponseTransformer="return "
      openAPIRequestBody=""
      query="1fpwi905j91c28jq0wvqfv5bfyjb6r66
"
      resourceName="Integromat 2.0 Webhook"
      runWhenModelUpdates={false}
      type="POST"
    >
      <Event
        id="5c9da905"
        event="success"
        method="trigger"
        params={{}}
        pluginId="get_inventory_gsheet"
        type="datasource"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="36367045"
        enabled=""
        event="success"
        method="setValue"
        params={{
          map: {
            value: "{{ import_gsheet.data.map(row => row.vin).join(',') }}",
          },
        }}
        pluginId="defaultVinsFilter"
        type="state"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="75fb48fc"
        event="success"
        method="trigger"
        params={{}}
        pluginId="get_raas_inventory"
        type="datasource"
        waitMs="0"
        waitType="debounce"
      />
    </RESTQuery>
    <RESTQuery
      id="create_supply_order"
      body={
        '[{"key":"title","value":"{{ post_order_title_txt.value }}"},{"key":"{{ post_order_transfer_of_risk.value ? \'transfer_of_risk\' : \'\' }}","value":"{{ post_order_transfer_of_risk.value }}"},{"key":"{{ post_order_price_inclusion_type.value ? \'price_inclusion_type\' : \'\' }}","value":"{{ post_order_price_inclusion_type.value }}"},{"key":"{{ post_order_defleeting_logistics.value ? \'defleeting_logistics\' : \'\' }}","value":"{{ post_order_defleeting_logistics.value }}"},{"key":"{{ post_order_remarketing_window.value ? \'remarketing_window_days_after_defleeting\' : \'\' }}","value":"{{ post_order_remarketing_window.value }}"},{"key":"{{ post_order_payment_required_for_car_handover.value ? \'payment_required_for_car_handover\' : \'\' }}","value":"{{ post_order_payment_required_for_car_handover.value }}"},{"key":"{{ post_order_payment_required_for_paper_handover.value ? \'payment_required_for_paper_handover\' : \'\' }}","value":"{{ post_order_payment_required_for_paper_handover.value }}"},{"key":"partner_id","value":"{{ post_order_partner.selectedItem?.partner_id }}"},{"key":"raas_type","value":"{{ post_order_type.value }}"},{"key":"{{ post_order_remarketing_end_trigger.value ? \'remarketing_end_trigger\' : \'\' }}","value":"{{ post_order_remarketing_end_trigger.value }}"},{"key":"{{ post_order_remarketing_end_trigger_latest.value ? \'remarketing_end_trigger_latest\' : \'\' }}","value":"{{ post_order_remarketing_end_trigger_latest.value }}"},{"key":"{{ post_order_delivery_charges.value ? \'other_deductibles\' : \'\' }}","value":"{{ [{\\"description\\": \\"delivery\\", \\"value\\":post_order_delivery_charges.value}] }}"}]'
      }
      bodyType="json"
      clonedDemoResourceType="restapi"
      cookies="[]"
      enableMockResponseTransformer={true}
      isClonedDemoQuery={true}
      isMultiplayerEdited={false}
      mockResponseTransformer="return "
      openAPIRequestBody=""
      query="supply-orders"
      resourceName="ad969d3c-fd67-41e3-9c5f-6ff3a154bdb4"
      resourceTypeOverride=""
      runWhenModelUpdates={false}
      type="POST"
    >
      <Event
        id="eae8741e"
        enabled="{{ !create_supply_order.isFetching }}"
        event="success"
        method="run"
        params={{
          map: {
            src: "console.log(create_supply_order.data);\n\nawait create_supply_trades.trigger({\n  additionalScope: {\n    supply_order_id: create_supply_order.data?.data?.supply_order_id\n  }\n})",
          },
        }}
        pluginId=""
        type="script"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="075edc16"
        event="success"
        method="setValue"
        params={{ map: { value: "{{ create_supply_order.data?.data }}" } }}
        pluginId="selected_order"
        type="state"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="1a60f930"
        event="success"
        method="setCurrentView"
        params={{ map: { viewKey: "get_order" } }}
        pluginId="tabbedContainer1"
        type="widget"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="3d00fbc4"
        event="success"
        method="trigger"
        params={{}}
        pluginId="list_supply_trades"
        type="datasource"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="d1461b2e"
        event="success"
        method="trigger"
        params={{}}
        pluginId="resetCreateSupplyOrderProperties"
        type="datasource"
        waitMs="0"
        waitType="debounce"
      />
    </RESTQuery>
    <RESTQuery
      id="create_supply_trades"
      _additionalScope={["supply_order_id"]}
      body={
        '{\n  "trades": {{ carsToMarkAsRaasSelection_step3.data\n    .map((car) => {\n  return {\n    finn_car_id: car.finn_car_id,\n    ...(post_order_mileage_allowance.value && {\n      mileage_allowance: post_order_mileage_allowance.value\n    }),\n    ...(post_order_mileage_fee.value && {\n        mileage_flat_discount: post_order_mileage_fee.value\n    }),\n    ...(post_order_damage_allowance.value && {\n      damage_allowance: post_order_damage_allowance.value\n    }),\n    ...(car.no_return_bonus_compensation_net && {\n      no_return_bonus_compensation_net: car.no_return_bonus_compensation_net\n    }),\n    ...(car.no_return_notification_date && {\n      no_return_notification_date: car.no_return_notification_date\n    }),\n    purchase_price_net: car.purchase_price\n  }\n}) }}\n}'
      }
      bodyType="raw"
      clonedDemoResourceType="restapi"
      cookies={'[{"key":"","value":""},{"key":"","value":""}]'}
      enableMockResponseTransformer={true}
      isClonedDemoQuery={true}
      isMultiplayerEdited={false}
      mockResponseTransformer="return "
      openAPIRequestBody=""
      query="supply-orders/{{Number(supply_order_id)}}/supply-trades"
      resourceName="4f137feb-cba2-4664-aaf5-14a80b2761ec"
      runWhenModelUpdates={false}
      type="POST"
    >
      <Event
        id="9770e362"
        event="success"
        method="showNotification"
        params={{
          map: {
            options: {
              notificationType: "success",
              title: "Successfully added cars to Supply Order",
            },
          },
        }}
        pluginId=""
        type="util"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="85f0990f"
        event="success"
        method="trigger"
        params={{}}
        pluginId="finalizeCreateSupplyOrder"
        type="datasource"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="ffdedd1f"
        event="success"
        method="hide"
        params={{}}
        pluginId="addRaasSupplyModalFrame"
        type="widget"
        waitMs="0"
        waitType="debounce"
      />
    </RESTQuery>
    <JavascriptQuery
      id="finalizeCreateSupplyOrder"
