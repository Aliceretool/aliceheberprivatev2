      query={
        "cars/raas?{{ vins_filter.value != \"\" ? 'vins' : null }}={{ vins_filter.value ? vins_filter.value : '' }}&{{ finnCarIds_filter.value != \"\" ? 'finnCarIds' : null }}={{ finnCarIds_filter.value ? finnCarIds_filter.value : '' }}&currentPage={{ raas_cars.pagination.currentPage+1 }}&perPage=500&{{ supplyType_filter.value.length > 0 ? 'raasTypes' : null }}={{ supplyType_filter.value ? supplyType_filter.value.join(',') : '' }}&{{ carStatus_filter.value.length > 0 ? 'carStatus' : null }}={{ carStatus_filter.value ? carStatus_filter.value.join(',') : '' }}&{{ brandNames_filter.value.length ? 'brandNames' : null }}={{ brandNames_filter.value ? brandNames_filter.value.join(',') : '' }}&{{ modelNames_filter.value.length ? 'modelNames' : null }}={{ modelNames_filter.value ? modelNames_filter.value.join(',') : '' }}&{{ availability_filter.value ? 'availability' : null }}={{ availability_filter.value ? availability_filter.value : '' }}&{{ supplyPartner_filter.value ? 'supplierIds' : null }}={{ supplyPartner_filter.value }}&{{ remarketingPartner_filter.value ? 'buyerIds' : null }}={{ remarketingPartner_filter.value }}&{{ supplyOrder_filter.value ? 'supplyOrderIds' : null }}={{ supplyOrder_filter.value }}"
      }
      queryTimeout="120000"
      resourceName="ad969d3c-fd67-41e3-9c5f-6ff3a154bdb4"
      resourceTypeOverride=""
      runWhenModelUpdates={false}
      runWhenPageLoads={true}
    >
      <Event
        id="1dc96a2a"
        enabled="{{ import_gsheet.data?.length > 0 }}"
        event="success"
        method="setValue"
        params={{
          map: {
            value:
              "{{\nget_raas_inventory.data.data?.map(car => {\n      const updateData = import_gsheet.data;\n      const newPrice = updateData?.find(row => row.vin === car.vin)?.Price;\n      return {\n        ...car,\n        supply_trade: {\n          ...car.supply_trade,\n          purchase_price_net: newPrice\n        }\n      }\n    })\n}}",
          },
        }}
        pluginId="raasInventory"
        type="state"
        waitMs="0"
        waitType="debounce"
      />
      <Event
        id="e6894246"
        enabled="{{ !import_gsheet.data || (import_gsheet.data && import_gsheet.data?.length == 0) }}"
        event="success"
        method="setValue"
        params={{ map: { value: "{{ get_raas_inventory.data.data }}" } }}
        pluginId="raasInventory"
        type="state"
        waitMs=""
        waitType="debounce"
      />
    </RESTQuery>
