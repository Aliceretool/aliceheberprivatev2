      mockResponseTransformer="return "
      notificationDuration={4.5}
      openAPIRequestBody=""
      query="cars/raas?supplyOrderIds={{ selected_order.value?.supply_order_id }}&perPage={{ trades_in_order.pagination.pageSize }}&currentPage={{ trades_in_order.pagination.currentPage + 1 }}"
      queryTimeout="30000"
      resourceName="4f137feb-cba2-4664-aaf5-14a80b2761ec"
      runWhenModelUpdates={false}
      showSuccessToaster={false}
      transformer="return {
  inventory: data.data.inventory.map(car => {
    return {
      vin: car.vin,
      finn_car_id: car.finn_car_id,
      brand: car.brand,
      model: car.model,
      supply_order_id: car.supply_order.supply_order_id,
      ...car.supply_trade
    }
  }),
  pagination: data.data.pagination
}"
      watchedParams={[
        "trades_in_order.pagination.pageSize",
        "trades_in_order.pagination.currentPage + 1",
      ]}
    />
